{
  "name": "product-schema",
  "description": "Schema for extracting product records",
  "config": {
    "rowSelector": ".product",
    "ignoreErrors": false,
    "limit": 0
  },
  "fields": {
    "title": {
      "selector": ".title",
      "type": "text",
      "required": true
    },
    "price": {
      "selector": ".price",
      "type": "number",
      "required": false,
      "numberOptions": {
        "stripNonNumeric": true,
        "precision": 2
      }
    },
    "description": {
      "selector": ".desc",
      "type": "text",
      "required": false
    },
    "link": {
      "selector": ".buy",
      "type": "attribute",
      "attribute": "href",
      "required": true
    },
    "inStock": {
      "selector": ".inStock",
      "type": "boolean",
      "required": false,
      "booleanOptions": {
        "mode": "mapping",
        "trueValues": ["in stock", "available", "yes"],
        "falseValues": ["out of stock", "no"]
      }
    }
  }
}
